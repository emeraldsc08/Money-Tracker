generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum TransactionType {
  INCOME
  OUTCOME
}

model Transaction {
  id          String          @id @default(cuid())
  type        TransactionType
  date        DateTime
  source      String
  amount      Decimal
  title       String
  category    String
  description String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}
